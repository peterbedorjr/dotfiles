[user]
	name = Peter Bedor
	email = peter@smarterlabor.com

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[pull]
	rebase = true

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Dracula
	minus-style = "syntax #3a1f2b"
	plus-style = "syntax #1f3a27"

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[alias]
	co = checkout
	br = branch
	st = status
	last = log -1 HEAD
	undo = reset HEAD~1 --mixed
	amend = commit --amend --no-edit
	wip = !git add -A && git commit -m 'wip'
	graph = log --oneline --graph --decorate --all

[http]
	postBuffer = 524288000

[pack]
	windowMemory = 256m
	packSizeLimit = 256m
